ont-weight: 600;\r\n  color: #111827;\r\n}\r\n\r\n.link-button {\r\n  border: none;\r\n  padding: 0;\r\n  background: none;\r\n  font-size: 13px;\r\n  color: #2563eb;\r\n  cursor: pointer;\r\n}\r\n\r\n.link-button:hover {\r\n  text-decoration: underline;\r\n}\r\n\r\n.room-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(3, minmax(0, 1fr));\r\n  gap: 16px;\r\n}\r\n\r\n.room-card {\r\n  border-radius: 16px;\r\n  padding: 14px 14px 12px;\r\n  background: #f9fafb;\r\n  border: 1px solid #e5e7eb;\r\n  display: grid;\r\n  gap: 10px;\r\n}\r\n\r\n.room-card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  font-size: 11px;\r\n}\r\n\r\n.room-status {\r\n  padding: 4px 10px;\r\n  border-radius: 999px;\r\n  font-weight: 600;\r\n}\r\n\r\n.room-status-running {\r\n  background: #dcfce7;\r\n  color: #166534;\r\n}\r\n\r\n.room-status-waiting {\r\n  background: #fef9c3;\r\n  color: #854d0e;\r\n}\r\n\r\n.room-slot {\r\n  color: #6b7280;\r\n}\r\n\r\n.room-card-body {\r\n  display: grid;\r\n  gap: 4px;\r\n}\r\n\r\n.room-name {\r\n  margin: 0;\r\n  font-size: 15px;\r\n  font-weight: 600;\r\n  color: #111827;\r\n}\r\n\r\n.room-subject {\r\n  margin: 0;\r\n  font-size: 12px;\r\n  color: #6b7280;\r\n}\r\n\r\n.room-examiner {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 6px;\r\n  font-size: 12px;\r\n  color: #374151;\r\n  margin-top: 6px;\r\n}\r\n\r\n.room-examiner-icon {\r\n  width: 20px;\r\n  height: 20px;\r\n  border-radius: 999px;\r\n  background: #e5e7eb;\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n.room-card-footer {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  font-size: 12px;\r\n  color: #6b7280;\r\n}\r\n\r\n.room-time {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 4px;\r\n}\r\n\r\n.room-count {\r\n  font-weight: 600;\r\n}\r\n\r\n.overview-right section {\r\n  background: #f9fafb;\r\n  border-radius: 1