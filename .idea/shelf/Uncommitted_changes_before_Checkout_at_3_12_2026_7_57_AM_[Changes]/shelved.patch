<+>/* =====================================\r\n   VARIABLES\r\n===================================== */\r\n:root {\r\n  --font-family: \"Roboto\", Arial, sans-serif;\r\n\r\n  --color-primary: #1e88e5;\r\n  --color-primary-dark: #1565c0;\r\n  --color-success: #43a047;\r\n\r\n  --color-bg: #f5f7fa;\r\n  --color-surface: #ffffff;\r\n  --color-border: #e0e0e0;\r\n  --color-border-light: #eeeeee;\r\n  --color-muted: #888888;\r\n\r\n  --radius-sm: 6px;\r\n  --radius-md: 10px;\r\n  --radius-pill: 20px;\r\n\r\n  --space-xs: 6px;\r\n  --space-sm: 8px;\r\n  --space-md: 12px;\r\n  --space-lg: 16px;\r\n}\r\n\r\n/* =====================================\r\n   BASE\r\n===================================== */\r\nbody {\r\n  margin: 0;\r\n  font-family: var(--font-family);\r\n  background: var(--color-bg);\r\n  color: #222;\r\n}\r\n\r\n/* =====================================\r\n   PAGE LAYOUT (95vh FIXED)\r\n===================================== */\r\n.score-manage-page {\r\n  padding: var(--space-lg);\r\n  height: 93vh;\r\n  box-sizing: border-box;\r\n}\r\n\r\n.score-manage-grid {\r\n  display: grid;\r\n  gap: var(--space-lg);\r\n  grid-template-columns: 1.6fr 1fr;\r\n  width: 100%;\r\n  height: 100%;\r\n  min-height: 0;\r\n}\r\n\r\n/* =====================================\r\n   LEFT COLUMN\r\n===================================== */\r\n.score-left {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--space-lg);\r\n  height: 100%;\r\n  min-height: 0;\r\n}\r\n\r\n/* =====================================\r\n   HEADER\r\n===================================== */\r\n.student-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.pill.primary {\r\n  background: var(--color-primary);\r\n  color: #fff;\r\n  border: none;\r\n  padding: var(--space-sm) var(--space-lg);\r\n  border-radius: var(--radius-pill);\r\n  cursor: pointer;\r\n  font-weight: 500;\r\n  transition: 0.2s ease;\r\n}\r\n\r\n.pill.primary:hover {\r\n  background: var(--color-primary-dark);\r\n}\r\n\r\n/* =====================================\r\n   FILTER\r\n===================================== */\r\n.subject-filter select {\r\n  padding: var(--space-xs) 10px;\r\n  border-radius: var(--radius-sm);\r\n  border: 1px solid var(--color-border);\r\n  font-size: 14px;\r\n}\r\n\r\n/* =====================================\r\n   TABLE WRAPPER (ONLY THIS SCROLLS)\r\n===================================== */\r\n.student-table-wrap {\r\n  flex: 1;\r\n  min-height: 0;\r\n  overflow-y: auto;\r\n  overflow-x: hidden;\r\n\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-md);\r\n  background: var(--color-surface);\r\n}\r\n\r\n/* =====================================\r\n   TABLE\r\n===================================== */\r\n.student-table {\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n  font-size: 14px;\r\n}\r\n\r\n.student-table thead {\r\n  position: sticky;\r\n  top: 0;\r\n  z-index: 2;\r\n}\r\n\r\n.student-table th {\r\n  background: var(--color-primary);\r\n  color: #fff;\r\n  padding: var(--space-sm);\r\n  text-align: left;\r\n  font-weight: 500;\r\n}\r\n\r\n.student-table td {\r\n  padding: var(--space-sm);\r\n  border-bottom: 1px solid var(--color-border-light);\r\n}\r\n\r\n.student-table tr {\r\n  cursor: pointer;\r\n  transition: background 0.15s ease;\r\n}\r\n\r\n.student-table tr:hover {\r\n  background: #f2f8ff;\r\n}\r\n\r\n.student-table tr.active {\r\n  background: #e3f2fd;\r\n}\r\n\r\n/* =====================================\r\n   EXPORT BUTTON\r\n===================================== */\r\n.export-btn {\r\n  align-self: flex-start;\r\n  background: var(--color-success);\r\n  color: #fff;\r\n  border: none;\r\n  border-radius: var(--radius-sm);\r\n  padding: var(--space-xs) var(--space-md);\r\n  cursor: pointer;\r\n  font-size: 13px;\r\n  transition: 0.2s ease;\r\n}\r\n\r\n.export-btn:hover {\r\n  opacity: 0.9;\r\n}\r\n\r\n/* =====================================\r\n   RIGHT PANEL\r\n===================================== */\r\n.score-panel {\r\n  background: var(--color-surface);\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-md);\r\n  padding: var(--space-lg);\r\n\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--space-lg);\r\n\r\n  height: 100%;\r\n  min-height: 0;\r\n  \r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);\r\n  overflow-y: auto;\r\n}\r\n\r\n/* =====================================\r\n   VIDEO BOX\r\n===================================== */\r\n.video-box {\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  min-height: 140px;\r\n\r\n  border-radius: var(--radius-md);\r\n  font-size: 48px;\r\n  color: var(--color-muted);\r\n\r\n  background: linear-gradient(135deg, #f0f4f8, #e9ecf0);\r\n  border: 1px solid #d9e3eb;\r\n  transition: 0.2s ease;\r\n}\r\n\r\n.video-box:hover {\r\n  background: linear-gradient(135deg, #e8f2ff, #e0ebf7);\r\n  border-color: var(--color-primary);\r\n}\r\n\r\n/* =====================================\r\n   DETAIL CARD\r\n===================================== */\r\n.detail-card {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n}\r\n\r\n/* =====================================\r\n   FORM FIELDS\r\n===================================== */\r\n.detail-fields {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n  padding: 10px 0;\r\n  border-top: 1px solid var(--color-border);\r\n  border-bottom: 1px solid var(--color-border);\r\n\r\n}\r\n\r\n.form-row {\r\n  display: grid;\r\n  grid-template-columns: 120px 1fr;\r\n  column-gap: 16px;\r\n  align-items: center;\r\n  /* labels right-aligned, values left-aligned */\r\n}\r\n\r\n.form-row label {\r\n  text-align: right;\r\n}\r\n\r\n.form-row div,\r\n.form-row input,\r\n.form-row textarea {\r\n  text-align: left;\r\n}\r\n\r\n.form-row label {\r\n  font-weight: 600;\r\n  font-size: 13px;\r\n}\r\n\r\n.form-row div {\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n}\r\n\r\n.form-row input,\r\n.form-row textarea {\r\n  width: 100%;\r\n  padding: 6px 8px;\r\n  border: 1px solid var(--color-border);\r\n  border-radius: var(--radius-sm);\r\n  font-size: 13px;\r\n  font-family: inherit;\r\n  transition: 0.2s;\r\n}\r\n\r\n.form-row input:focus,\r\n.form-row textarea:focus {\r\n  outline: none;\r\n  border-color: var(--color-primary);\r\n  box-shadow: 0 0 0 2px rgba(30, 136, 229, 0.15);\r\n}\r\n\r\n.form-row input:disabled,\r\n.form-row textarea:disabled {\r\n  background: #f5f5f5;\r\n  color: #999;\r\n  cursor: not-allowed;\r\n}\r\n\r\n/* =====================================\r\n   ACTION BUTTONS\r\n===================================== */\r\n.detail-actions {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  gap: var(--space-sm);\r\n}\r\n\r\n.btn {\r\n  padding: var(--space-sm) var(--space-md);\r\n  border-radius: var(--radius-sm);\r\n  border: none;\r\n  font-size: 13px;\r\n  font-weight: 500;\r\n  cursor: pointer;\r\n  transition: 0.2s ease;\r\n}\r\n\r\n.btn.primary {\r\n  background: var(--color-primary);\r\n  color: #fff;\r\n}\r\n\r\n.btn.primary:hover {\r\n  background: var(--color-primary-dark);\r\n}\r\n\r\n.btn:hover {\r\n  opacity: 0.9;\r\n}
